---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);

const siteUrl   = 'https://navacerradavaron.com';
const canonicalUrl = locale === 'en' ? `${siteUrl}/en/` : `${siteUrl}/`;
const ogImage   = `${siteUrl}/og-image.svg`;

const jsonLd = [
    {
        '@context':  'https://schema.org',
        '@type':     'WebSite',
        name:        t.meta.jsonLd.websiteName,
        url:         canonicalUrl,
        description: t.meta.jsonLd.websiteDesc,
        inLanguage:  locale === 'en' ? 'en' : 'es-ES',
        author: {
            '@type': 'Person',
            name:    'Daniel Navacerrada Varón',
        },
    },
    {
        '@context':  'https://schema.org',
        '@type':     ['Person', 'ProfessionalService'],
        name:        'Daniel Navacerrada Varón',
        url:         canonicalUrl,
        image:       `${siteUrl}/logo.svg`,
        jobTitle:    t.meta.jsonLd.jobTitle,
        description: t.meta.jsonLd.personDesc,
        address: {
            '@type':           'PostalAddress',
            addressLocality:   'Madrid',
            addressRegion:     'Comunidad de Madrid',
            addressCountry:    'ES',
        },
        areaServed: {
            '@type': 'Country',
            name:    t.meta.jsonLd.areaServed,
        },
        knowsAbout: ['.NET', 'C#', 'Java', 'SQL Server', 'MySQL', 'N8N', 'OCR', 'Web Security', 'REST APIs', 'Business Automation', 'Web Development', 'Web Optimisation', 'Technical SEO'],
        hasOccupation: {
            '@type':            'Occupation',
            name:               t.meta.jsonLd.occupation,
            occupationLocation: { '@type': 'City', name: 'Madrid' },
            skills:             t.meta.jsonLd.skills,
        },
        makesOffer: t.meta.jsonLd.offers.map(o => ({
            '@type':      'Offer',
            itemOffered:  { '@type': 'Service', name: o.name, description: o.desc },
        })),
        sameAs:       ['https://www.linkedin.com/in/daniel-navacerrada-var%C3%B3n-9323821b8/'],
        contactPoint: {
            '@type':           'ContactPoint',
            contactType:       t.meta.jsonLd.contactType,
            email:             'info@navacerradavaron.com',
            availableLanguage: t.meta.jsonLd.langAvailable,
        },
    },
];
---
<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"  content={t.meta.description} />
    <meta name="keywords"     content={t.meta.keywords} />
    <meta name="robots"       content="index, follow" />
    <meta name="theme-color"  content="#080810" />
    <meta name="author"       content="Daniel Navacerrada Varón" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang (SEO multilingüe) -->
    <link rel="alternate" hreflang="es"        href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="en"        href={`${siteUrl}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Open Graph -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalUrl} />
    <meta property="og:title"        content={t.meta.title} />
    <meta property="og:description"  content={t.meta.description} />
    <meta property="og:locale"       content={locale === 'en' ? 'en_GB' : 'es_ES'} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={t.meta.ogAlt} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="icon" href="/logo.svg"       type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap"  href="/sitemap-index.xml" />

    <!-- Preload CSS crítico -->
    <link rel="preload" href="/styles/global.css" as="style" />
    <link rel="stylesheet" href="/styles/global.css" />

    <title>{t.meta.title}</title>

    <!-- Fuentes Google — carga no bloqueante (media trick) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" media="print" onload="this.media='all'"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>

    <!-- Google Analytics GA4 — carga diferida tras primera interacción -->
    <script>
        (function() {
            let loaded = false;
            function loadGA() {
                if (loaded) return;
                loaded = true;
                ['scroll','click','keydown','touchstart','mousemove'].forEach(function(ev) {
                    document.removeEventListener(ev, loadGA);
                });
                const s = document.createElement('script');
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-VB3NSL77SS';
                s.async = true;
                document.head.appendChild(s);
                window.dataLayer = window.dataLayer || [];
                function gtag(){ window.dataLayer.push(arguments); }
                window.gtag = gtag;
                gtag('js', new Date());
                gtag('config', 'G-VB3NSL77SS');
            }
            ['scroll','click','keydown','touchstart','mousemove'].forEach(function(ev) {
                document.addEventListener(ev, loadGA, { once: true, passive: true });
            });
            setTimeout(loadGA, 5000);
        })();
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
    <!-- Skip to content (accesibilidad teclado) -->
    <a href="#main-content" class="skip-link">
        {locale === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
    </a>

    <!-- Scroll progress bar -->
    <div class="scroll-progress" id="scrollProgress" role="progressbar"
         aria-label={locale === 'en' ? 'Reading progress' : 'Progreso de lectura'}></div>

    <!-- Background blobs -->
    <div class="blob blob-1" aria-hidden="true"></div>
    <div class="blob blob-2" aria-hidden="true"></div>
    <div class="blob blob-3" aria-hidden="true"></div>

    <main id="main-content">
        <slot />
    </main>

    <script>
        // ── Scroll progress bar (scrollHeight cacheado, sin reflow en cada scroll) ──
        const bar = document.getElementById('scrollProgress')!;
        let totalHeight = document.body.scrollHeight - window.innerHeight;
        window.addEventListener('resize', () => {
            totalHeight = document.body.scrollHeight - window.innerHeight;
        }, { passive: true });
        window.addEventListener('scroll', () => {
            const pct = totalHeight > 0 ? (window.scrollY / totalHeight) * 100 : 0;
            bar.style.width = pct + '%';
        }, { passive: true });

        // ── Staggered scroll reveal ──
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    io.unobserve(e.target);
                }
            });
        }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

        document.querySelectorAll('.projects-grid, .services-grid, .skills-list, .timeline').forEach(grid => {
            grid.querySelectorAll('.reveal').forEach((el, i) => {
                el.setAttribute('data-delay', String((i % 6) + 1));
            });
        });

        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
        setTimeout(() => {
            document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
        }, 1500);

        // ── Stats counter animation (requestAnimationFrame) ──
        const counters = document.querySelectorAll('.stat-number');
        const counterIO = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (!e.isIntersecting) return;
                const el     = e.target as HTMLElement;
                const target = parseInt(el.dataset.target || '0');
                const dur    = 1200;
                const start  = performance.now();
                const animate = (now: number) => {
                    const progress = Math.min((now - start) / dur, 1);
                    el.textContent = Math.floor(progress * target) + '+';
                    if (progress < 1) requestAnimationFrame(animate);
                };
                requestAnimationFrame(animate);
                counterIO.unobserve(el);
            });
        }, { threshold: 0.5 });

        counters.forEach(c => {
            const val = parseInt((c as HTMLElement).textContent || '0');
            (c as HTMLElement).dataset.target = String(val);
            (c as HTMLElement).textContent = '0+';
            counterIO.observe(c);
        });

        // ── Project card tilt (lerp suavizado) ──
        document.querySelectorAll('.project-card').forEach(card => {
            const el = card as HTMLElement;
            let targetX = 0, targetY = 0;
            let currentX = 0, currentY = 0;
            let isHovered = false;
            let rafId = 0;

            const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

            const animate = () => {
                currentX = lerp(currentX, targetX, 0.1);
                currentY = lerp(currentY, targetY, 0.1);
                const dx = Math.abs(currentX - targetX);
                const dy = Math.abs(currentY - targetY);
                el.style.transform = isHovered
                    ? `perspective(900px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateY(-6px) scale(1.02)`
                    : `perspective(900px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateY(0px) scale(1)`;
                if (dx > 0.01 || dy > 0.01 || isHovered) {
                    rafId = requestAnimationFrame(animate);
                } else {
                    el.style.transform = '';
                    cancelAnimationFrame(rafId);
                }
            };

            el.addEventListener('mouseenter', () => { isHovered = true; rafId = requestAnimationFrame(animate); });
            let lastMove = 0;
            el.addEventListener('mousemove', (e) => {
                const now = Date.now();
                if (now - lastMove < 16) return;
                lastMove = now;
                const rect = el.getBoundingClientRect();
                const x    = (e as MouseEvent).clientX - rect.left;
                const y    = (e as MouseEvent).clientY - rect.top;
                targetX    = ((y - rect.height / 2) / rect.height) * -8;
                targetY    = ((x - rect.width  / 2) / rect.width)  *  8;
            });
            el.addEventListener('mouseleave', () => {
                isHovered = false; targetX = 0; targetY = 0;
                rafId = requestAnimationFrame(animate);
            });
        });
    </script>
</body>
</html>
