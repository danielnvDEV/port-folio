---
interface Props {
    title?: string;
    description?: string;
}
const {
    title       = 'Daniel Navacerrada — Desarrollador de Software en Madrid',
    description = 'Portfolio de Daniel Navacerrada Varón, desarrollador de software en Madrid especializado en .NET, Java, automatización con N8N y seguridad web. Disponible para proyectos freelance.',
} = Astro.props;

const siteUrl   = 'https://navacerradavaron.com';
const ogImage   = `${siteUrl}/logo.svg`;

const jsonLd = [
    {
        '@context': 'https://schema.org',
        '@type':    'WebSite',
        name:       'Daniel Navacerrada — Desarrollador de Software',
        url:        siteUrl,
        description: 'Portfolio de Daniel Navacerrada Varón, desarrollador de software en Madrid especializado en .NET, Java, automatización con N8N y seguridad web.',
        inLanguage: 'es-ES',
        author: {
            '@type': 'Person',
            name:    'Daniel Navacerrada Varón',
        },
    },
    {
        '@context':  'https://schema.org',
        '@type':     ['Person', 'ProfessionalService'],
        name:        'Daniel Navacerrada Varón',
        url:         siteUrl,
        image:       `${siteUrl}/logo.svg`,
        jobTitle:    'Desarrollador de Software Freelance',
        description: 'Desarrollador de software especializado en .NET, Java y automatización empresarial con N8N. Disponible para proyectos freelance en Madrid.',
        address: {
            '@type':           'PostalAddress',
            addressLocality:   'Madrid',
            addressRegion:     'Comunidad de Madrid',
            addressCountry:    'ES',
        },
        areaServed: {
            '@type': 'Country',
            name:    'España',
        },
        knowsAbout: ['.NET', 'C#', 'Java', 'SQL Server', 'MySQL', 'N8N', 'OCR', 'Seguridad Web', 'APIs REST', 'Automatización empresarial'],
        hasOccupation: {
            '@type':            'Occupation',
            name:               'Desarrollador de Software',
            occupationLocation: { '@type': 'City', name: 'Madrid' },
            skills:             '.NET, C#, Java, SQL Server, N8N, APIs REST, Seguridad Web',
        },
        sameAs:      ['https://www.linkedin.com/in/daniel-navacerrada-var%C3%B3n-9323821b8/'],
        contactPoint: {
            '@type':           'ContactPoint',
            contactType:       'customer service',
            email:             'info@navacerradavaron.com',
            availableLanguage: ['Spanish', 'English'],
        },
    },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"  content={description} />
    <meta name="keywords"     content="desarrollador software Madrid, freelance .NET, desarrollador C# Madrid, automatización N8N, API REST, Java developer Madrid, programador freelance España, seguridad web, SQL Server developer" />
    <meta name="robots"       content="index, follow" />
    <meta name="theme-color"  content="#080810" />
    <meta name="author"       content="Daniel Navacerrada Varón" />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={siteUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale"      content="es_ES" />
    <meta property="og:image"       content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicon -->
    <link rel="icon"      href="/logo.svg" type="image/svg+xml" />
    <link rel="sitemap"   href="/sitemap-index.xml" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VB3NSL77SS"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-VB3NSL77SS');
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
    <!-- Scroll progress bar -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <!-- Background blobs -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <main>
        <slot />
    </main>

    <script>
        // ── Scroll progress bar ──
        const bar = document.getElementById('scrollProgress')!;
        window.addEventListener('scroll', () => {
            const total  = document.body.scrollHeight - window.innerHeight;
            const pct    = total > 0 ? (window.scrollY / total) * 100 : 0;
            bar.style.width = pct + '%';
        }, { passive: true });

        // ── Staggered scroll reveal ──
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    io.unobserve(e.target);
                }
            });
        }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

        document.querySelectorAll('.projects-grid, .services-grid, .skills-list, .timeline').forEach(grid => {
            grid.querySelectorAll('.reveal').forEach((el, i) => {
                el.setAttribute('data-delay', String((i % 6) + 1));
            });
        });

        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
        setTimeout(() => {
            document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
        }, 1500);

        // ── Nav active on scroll ──
        const sections   = document.querySelectorAll('section[id]');
        const navAnchors = document.querySelectorAll('.nav-links a:not(.nav-cta)');
        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(s => { if (window.scrollY >= (s as HTMLElement).offsetTop - 220) current = s.id; });
            navAnchors.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + current));
        }, { passive: true });

        // ── Stats counter animation ──
        const counters = document.querySelectorAll('.stat-number');
        const counterIO = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (!e.isIntersecting) return;
                const el     = e.target as HTMLElement;
                const target = parseInt(el.dataset.target || '0');
                const dur    = 1200;
                const step   = 16;
                const inc    = target / (dur / step);
                let current  = 0;
                const timer  = setInterval(() => {
                    current += inc;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = Math.floor(current) + '+';
                }, step);
                counterIO.unobserve(el);
            });
        }, { threshold: 0.5 });

        counters.forEach(c => {
            const val = parseInt((c as HTMLElement).textContent || '0');
            (c as HTMLElement).dataset.target = String(val);
            (c as HTMLElement).textContent = '0+';
            counterIO.observe(c);
        });

        // ── Project card tilt (lerp suavizado) ──
        document.querySelectorAll('.project-card').forEach(card => {
            const el = card as HTMLElement;
            let targetX = 0, targetY = 0;
            let currentX = 0, currentY = 0;
            let isHovered = false;
            let rafId = 0;

            const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

            const animate = () => {
                currentX = lerp(currentX, targetX, 0.1);
                currentY = lerp(currentY, targetY, 0.1);
                const dx = Math.abs(currentX - targetX);
                const dy = Math.abs(currentY - targetY);
                el.style.transform = isHovered
                    ? `perspective(900px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateY(-6px) scale(1.02)`
                    : `perspective(900px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateY(0px) scale(1)`;
                if (dx > 0.01 || dy > 0.01 || isHovered) {
                    rafId = requestAnimationFrame(animate);
                } else {
                    el.style.transform = '';
                    cancelAnimationFrame(rafId);
                }
            };

            el.addEventListener('mouseenter', () => { isHovered = true; rafId = requestAnimationFrame(animate); });
            el.addEventListener('mousemove', (e) => {
                const rect = el.getBoundingClientRect();
                const x    = (e as MouseEvent).clientX - rect.left;
                const y    = (e as MouseEvent).clientY - rect.top;
                targetX    = ((y - rect.height / 2) / rect.height) * -8;
                targetY    = ((x - rect.width  / 2) / rect.width)  *  8;
            });
            el.addEventListener('mouseleave', () => {
                isHovered = false; targetX = 0; targetY = 0;
                rafId = requestAnimationFrame(animate);
            });
        });
    </script>
</body>
</html>
