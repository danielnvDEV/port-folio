---
const links = ['Sobre mí', 'Proyectos', 'Servicios', 'Contacto'];
const hrefs = ['#about', '#projects', '#services', '#contact'];
---
<footer>
    <div class="footer-inner">
        <div class="footer-copy">
            <p>© 2026 <span>Daniel Navacerrada Varón</span> · Hecho con ❤️ en Madrid</p>
        </div>
        <ul class="footer-links">
            {links.map((l, i) => <li><a href={hrefs[i]}>{l}</a></li>)}
        </ul>
    </div>
</footer>
