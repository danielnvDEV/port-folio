---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);
const s      = t.services;
---
<section id="services" aria-labelledby="services-title">
    <div class="container">
        <p class="section-label reveal">{s.label}</p>
        <h2 class="section-title reveal" id="services-title">{s.title}</h2>
        <p class="section-desc reveal">{s.desc}</p>

        <div class="webdev-grid">
            {s.offerings.map(o => (
                <article class="webdev-card reveal" style={`--card-accent:${o.accent};--card-bg:${o.bg};--card-border:${o.border}`}>
                    <div class="webdev-card-header">
                        <span class="webdev-label">{o.label}</span>
                        <span class="webdev-icon" role="img" aria-label={o.label}>{o.icon}</span>
                    </div>
                    <h3>{o.title}</h3>
                    <p class="webdev-desc">{o.desc}</p>
                    <ul class="webdev-features" aria-label={o.title}>
                        {o.features.map(f => (
                            <li>
                                <span class="webdev-check" aria-hidden="true">✓</span>
                                {f}
                            </li>
                        ))}
                    </ul>
                    <a href="#contact" class="webdev-cta" aria-label={`${o.cta} — ${o.title}`}>
                        {o.cta}
                    </a>
                </article>
            ))}
        </div>

        <div class="webdev-process reveal">
            <p class="webdev-process-title">{s.process.title}</p>
            <ol class="webdev-steps" aria-label={s.process.title}>
                {s.process.steps.map(step => (
                    <li class="webdev-step">
                        <span class="step-num" aria-hidden="true">{step.num}</span>
                        <strong>{step.title}</strong>
                        <span>{step.desc}</span>
                    </li>
                ))}
            </ol>
        </div>

        <div class="capabilities-wrap reveal">
            <p class="webdev-process-title">{s.capabilities.title}</p>
            <ul class="services-grid" style="list-style:none;padding:0">
                {s.capabilities.items.map(c => (
                    <li class="service-card reveal" role="article">
                        {c.badge && <span class="service-badge" aria-label={locale === 'en' ? 'Popular service' : 'Servicio popular'}>{c.badge}</span>}
                        <div class="service-icon" role="img" aria-label={c.title}>{c.icon}</div>
                        <h3>{c.title}</h3>
                        <p>{c.desc}</p>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</section>

<style>
#services {
    background: var(--bg);
    border-top: 1px solid var(--border);
}
.webdev-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
}
.webdev-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    transition: transform 0.3s, box-shadow 0.3s;
}
.webdev-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.2);
}
.webdev-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.webdev-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--card-accent);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
}
.webdev-icon {
    font-size: 1.8rem;
    line-height: 1;
}
.webdev-card h3 {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0;
}
.webdev-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0;
}
.webdev-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-grow: 1;
}
.webdev-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
}
.webdev-check {
    color: var(--card-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
}
.webdev-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--card-accent);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.3s;
}
.webdev-cta:hover { gap: 0.7rem; }

.webdev-process {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2.5rem;
    margin-bottom: 3.5rem;
}
.webdev-process-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--primary-light);
    margin-bottom: 1.5rem;
}
.webdev-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
}
.webdev-step {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
}
.webdev-step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 0.9rem;
    right: -0.75rem;
    width: 1.5rem;
    height: 1px;
    background: var(--border);
}
.step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--primary-light);
    opacity: 0.7;
}
.webdev-step strong {
    font-size: 0.875rem;
    color: var(--text-primary);
}
.webdev-step span:last-child {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.6;
}

.capabilities-wrap { margin-top: 0; }
.capabilities-wrap .webdev-process-title { margin-bottom: 1.25rem; }

@media (max-width: 768px) {
    .webdev-grid { grid-template-columns: 1fr; }
    .webdev-steps { grid-template-columns: 1fr 1fr; }
    .webdev-step:not(:last-child)::after { display: none; }
    .webdev-process { padding: 1.5rem; }
}
@media (max-width: 480px) {
    .webdev-steps { grid-template-columns: 1fr; }
}
</style>
