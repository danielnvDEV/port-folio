---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);
const a      = t.about;
---
<section id="about">
    <div class="container">
        <p class="section-label reveal">{a.label}</p>
        <h2 class="section-title reveal">{a.title}</h2>
        <div class="about-grid">
            <div class="about-text reveal">
                <p>{a.p1}</p>
                <p>{a.p2}</p>
                <p>{a.p3}</p>
                <a href="#contact" class="btn-primary" style="margin-top:1.5rem">{a.cta}</a>
            </div>
            <ul class="skills-list reveal" style="list-style:none;padding:0">
                {a.skills.map(s => (
                    <li class="skill-item">
                        <div class="skill-icon" role="img" aria-label={s.title}>{s.icon}</div>
                        <div class="skill-info">
                            <h3>{s.title}</h3>
                            <p>{s.desc}</p>
                        </div>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</section>
