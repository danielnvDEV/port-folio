---
const links = [
    { href: '#hero',       label: 'Inicio' },
    { href: '#about',      label: 'Sobre mí' },
    { href: '#experience', label: 'Experiencia' },
    { href: '#projects',   label: 'Proyectos' },
    { href: '#services',   label: 'Servicios' },
    { href: '#webdev',     label: 'Tu Web' },
    { href: '#contact',    label: 'Contacto' },
];
---
<nav aria-label="Navegación principal">
    <div class="nav-container">
        <a href="#hero" class="logo" aria-label="Daniel Navacerrada — Inicio">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 90" fill="none" width="53" height="31" aria-hidden="true">
                <defs>
                    <linearGradient id="navG" x1="0" y1="0" x2="155" y2="90" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#a78bfa"/>
                        <stop offset="1" stop-color="#ec4899"/>
                    </linearGradient>
                </defs>
                <!-- D -->
                <path fill="url(#navG)" fill-rule="evenodd" d="
                    M 8,8 L 8,82 L 28,82
                    C 56,82 63,66 63,45
                    C 63,24 56,8  28,8 Z
                    M 18,20 L 18,70 L 28,70
                    C 49,70 53,59 53,45
                    C 53,31 49,20 28,20 Z
                "/>
                <!-- N -->
                <path fill="url(#navG)" d="M 51,8 L 65,8 L 90,82 L 76,82 Z"/>
                <!-- V izquierdo -->
                <path fill="url(#navG)" d="M 79,8 L 93,8 L 110,82 L 96,82 Z"/>
                <!-- V derecho -->
                <path fill="url(#navG)" d="M 96,82 L 110,82 L 145,8 L 131,8 Z"/>
            </svg>
        </a>
        <button class="hamburger" id="menuBtn" aria-label="Abrir menú" aria-expanded="false" aria-controls="navLinks">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks" role="list">
            {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
            <li><a href="#contact" class="nav-cta">Contactar</a></li>
        </ul>
    </div>
</nav>

<script>
    const btn   = document.getElementById('menuBtn')!;
    const links = document.getElementById('navLinks')!;

    function closeMenu() {
        links.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Abrir menú');
    }

    btn.addEventListener('click', () => {
        const isOpen = links.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(isOpen));
        btn.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    });

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && links.classList.contains('open')) closeMenu();
    });

    links.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    // aria-current en link activo (offsetTop cacheado para evitar reflow en cada scroll)
    const sections   = document.querySelectorAll('section[id]');
    const navAnchors = links.querySelectorAll('a:not(.nav-cta)');

    type SectionTop = { id: string; top: number };
    let sectionTops: SectionTop[] = [];

    function cacheSectionTops() {
        sectionTops = Array.from(sections).map(s => ({
            id:  s.id,
            top: (s as HTMLElement).offsetTop,
        }));
    }
    cacheSectionTops();
    window.addEventListener('resize', cacheSectionTops, { passive: true });

    window.addEventListener('scroll', () => {
        let current = '';
        sectionTops.forEach(({ id, top }) => { if (window.scrollY >= top - 220) current = id; });
        navAnchors.forEach(a => {
            const isCurrent = a.getAttribute('href') === '#' + current;
            a.classList.toggle('active', isCurrent);
            isCurrent ? a.setAttribute('aria-current', 'page') : a.removeAttribute('aria-current');
        });
    }, { passive: true });
</script>
