---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);

const links = [
    { href: '#hero',       label: t.nav.inicio },
    { href: '#about',      label: t.nav.sobreMi },
    { href: '#projects',   label: t.nav.proyectos },
    { href: '#services',   label: t.nav.servicios },
    { href: '#experience', label: t.nav.experiencia },
];
---
<nav aria-label={locale === 'en' ? 'Main navigation' : 'Navegación principal'}>
    <div class="nav-container">
        <a href={locale === 'en' ? '/en/' : '/'} class="logo" aria-label="Daniel Navacerrada — Inicio">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 90" fill="none" width="53" height="31" aria-hidden="true">
                <defs>
                    <linearGradient id="navG" x1="0" y1="0" x2="155" y2="90" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#a78bfa"/>
                        <stop offset="1" stop-color="#ec4899"/>
                    </linearGradient>
                </defs>
                <!-- D -->
                <path fill="url(#navG)" fill-rule="evenodd" d="
                    M 8,8 L 8,82 L 28,82
                    C 56,82 63,66 63,45
                    C 63,24 56,8  28,8 Z
                    M 18,20 L 18,70 L 28,70
                    C 49,70 53,59 53,45
                    C 53,31 49,20 28,20 Z
                "/>
                <!-- N -->
                <path fill="url(#navG)" d="M 51,8 L 65,8 L 90,82 L 76,82 Z"/>
                <!-- V izquierdo -->
                <path fill="url(#navG)" d="M 79,8 L 93,8 L 110,82 L 96,82 Z"/>
                <!-- V derecho -->
                <path fill="url(#navG)" d="M 96,82 L 110,82 L 145,8 L 131,8 Z"/>
            </svg>
        </a>
        <button class="hamburger" id="menuBtn"
                aria-label={locale === 'en' ? 'Open menu' : 'Abrir menú'}
                aria-expanded="false" aria-controls="navLinks">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks" role="list">
            {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
            <li>
                <a href={t.nav.langSwitchHref}
                   class="lang-btn"
                   aria-label={t.nav.langSwitch}
                   hreflang={locale === 'en' ? 'es' : 'en'}>
                    {t.nav.langSwitch}
                </a>
            </li>
            <li><a href="#contact" class="nav-cta">{t.nav.contactar}</a></li>
        </ul>
    </div>
</nav>

<style>
.lang-btn {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text-secondary) !important;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0.7rem !important;
    transition: all 0.3s !important;
    text-decoration: none;
}
.lang-btn::after { display: none !important; }
.lang-btn:hover {
    color: var(--primary-light) !important;
    border-color: rgba(124,58,237,0.4) !important;
    background: rgba(124,58,237,0.06) !important;
}
</style>

<script>
    const btn   = document.getElementById('menuBtn')!;
    const links = document.getElementById('navLinks')!;

    function closeMenu() {
        links.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', () => {
        const isOpen = links.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(isOpen));
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && links.classList.contains('open')) closeMenu();
    });

    links.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    // aria-current en link activo (offsetTop cacheado para evitar reflow en cada scroll)
    const sections   = document.querySelectorAll('section[id]');
    const navAnchors = links.querySelectorAll('a:not(.nav-cta):not(.lang-btn)');

    type SectionTop = { id: string; top: number };
    let sectionTops: SectionTop[] = [];

    function cacheSectionTops() {
        sectionTops = Array.from(sections).map(s => ({
            id:  s.id,
            top: (s as HTMLElement).offsetTop,
        }));
    }
    cacheSectionTops();
    window.addEventListener('resize', cacheSectionTops, { passive: true });

    window.addEventListener('scroll', () => {
        let current = '';
        sectionTops.forEach(({ id, top }) => { if (window.scrollY >= top - 220) current = id; });
        navAnchors.forEach(a => {
            const isCurrent = a.getAttribute('href') === '#' + current;
            a.classList.toggle('active', isCurrent);
            isCurrent ? a.setAttribute('aria-current', 'page') : a.removeAttribute('aria-current');
        });
    }, { passive: true });
</script>
