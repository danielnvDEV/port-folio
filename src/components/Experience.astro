---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);
const e      = t.experience;
---
<section id="experience">
    <div class="container">
        <p class="section-label reveal">{e.label}</p>
        <h2 class="section-title reveal">{e.title}</h2>
        <p class="section-desc reveal">{e.desc}</p>
        <ol class="timeline" style="list-style:none;padding:0">
            {e.jobs.map(j => (
                <li class="timeline-item reveal">
                    <div class="timeline-dot" aria-hidden="true"></div>
                    <div class="timeline-period">{j.period}</div>
                    <div class="timeline-role">{j.role}</div>
                    <div class="timeline-company">{j.company}</div>
                    <div class="timeline-desc">{j.desc}</div>
                    <div class="timeline-tags">
                        {j.tags.map(tag => <span class="timeline-tag">{tag}</span>)}
                    </div>
                </li>
            ))}
        </ol>
    </div>
</section>
