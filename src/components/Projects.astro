---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);
const p      = t.projects;
---
<section id="projects">
    <div class="container">
        <p class="section-label reveal">{p.label}</p>
        <h2 class="section-title reveal">{p.title}</h2>
        <p class="section-desc reveal">{p.desc}</p>
        <ul class="projects-grid" style="list-style:none;padding:0">
            {p.items.map(item => (
                <li class="project-card reveal">
                    <div class={`project-thumb ${item.thumb}`} aria-hidden="true">
                        <span class="project-icon" role="img" aria-label={item.title}>{item.icon}</span>
                        <div class="project-num">{item.num}</div>
                    </div>
                    <div class="project-body">
                        <h3>{item.title}</h3>
                        <p>{item.desc}</p>
                        <div class="project-tags" aria-label={locale === 'en' ? 'Technologies used' : 'Tecnologías usadas'}>
                            {item.tags.map(tag => <span class="tag">{tag}</span>)}
                        </div>
                        <a href={item.link}
                           target={item.external ? '_blank' : undefined}
                           rel={item.external ? 'noopener noreferrer' : undefined}
                           class="project-link"
                           aria-label={`${item.external ? p.visitLabel : p.moreLabel} — ${item.title}`}>
                            {item.external ? p.visitLabel : p.moreLabel}
                        </a>
                    </div>
                </li>
            ))}
        </ul>
    </div>
</section>
