---
import { useTranslations } from '../i18n/translations';

const locale = Astro.currentLocale ?? 'es';
const t      = useTranslations(locale);
const c      = t.contact;
const f      = c.form;

const socials = [
    {
        title: 'LinkedIn',
        href: 'https://www.linkedin.com/in/daniel-navacerrada-var%C3%B3n-9323821b8/',
        svg: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>`,
    },
];
---
<section id="contact">
    <div class="container">
        <p class="section-label reveal">{c.label}</p>
        <h2 class="section-title reveal">{c.title}</h2>
        <div class="contact-wrapper">
            <div class="contact-info-col reveal">
                <h3>{c.h3}</h3>
                <p>{c.p}</p>
                <div class="contact-detail">
                    <div class="contact-detail-icon" role="img" aria-label={c.details.location.label}>📍</div>
                    <div><span>{c.details.location.label}</span><strong>{c.details.location.value}</strong></div>
                </div>
                <div class="contact-detail">
                    <div class="contact-detail-icon" role="img" aria-label={c.details.availability.label}>🕐</div>
                    <div><span>{c.details.availability.label}</span><strong>{c.details.availability.value}</strong></div>
                </div>
                <div class="contact-detail">
                    <div class="contact-detail-icon" role="img" aria-label={c.details.languages.label}>💬</div>
                    <div><span>{c.details.languages.label}</span><strong>{c.details.languages.value}</strong></div>
                </div>
                <div class="social-row">
                    {socials.map(s => (
                        <a href={s.href} target="_blank" rel="noopener noreferrer me" class="social-btn" title={s.title} set:html={s.svg} />
                    ))}
                </div>
            </div>

            <form class="contact-form reveal" id="contactForm" novalidate
                  aria-label={locale === 'en' ? 'Contact form' : 'Formulario de contacto'}
                  data-submit={f.submit}
                  data-sending={f.sending}
                  data-success={f.success}
                  data-error={f.error}
                  data-val-nombre-req={t.contact.validation.nombreReq}
                  data-val-email-req={t.contact.validation.emailReq}
                  data-val-email-invalid={t.contact.validation.emailInvalid}
                  data-val-mensaje-req={t.contact.validation.mensajeReq}
                  data-val-mensaje-short={t.contact.validation.mensajeShort}>

                <!-- Honeypot anti-spam (oculto para humanos) -->
                <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none" aria-hidden="true">
                    <label for="website">No rellenar</label>
                    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="nombre">{f.nombre} <span class="field-required" aria-label={f.requerido}>*</span></label>
                        <input type="text" id="nombre" placeholder={f.nombrePh} required autocomplete="name"
                               aria-describedby="error-nombre" aria-required="true" />
                        <span class="field-error" id="error-nombre" aria-live="polite"></span>
                    </div>
                    <div class="form-group">
                        <label for="email">{f.email} <span class="field-required" aria-label={f.requerido}>*</span></label>
                        <input type="email" id="email" placeholder={f.emailPh} required autocomplete="email"
                               aria-describedby="error-email" aria-required="true" />
                        <span class="field-error" id="error-email" aria-live="polite"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label for="asunto">{f.asunto} <span style="font-size:0.72rem;color:var(--text-secondary)">{f.opcional}</span></label>
                    <select id="asunto">
                        <option value="">{f.asuntoPh}</option>
                        <optgroup label={f.groups.webDev}>
                            <option>{f.options.webNueva}</option>
                            <option>{f.options.mejorarWeb}</option>
                            <option>{f.options.fullStack}</option>
                        </optgroup>
                        <optgroup label={f.groups.backend}>
                            <option>{f.options.backend}</option>
                        </optgroup>
                        <optgroup label={f.groups.specialties}>
                            <option>{f.options.n8n}</option>
                            <option>{f.options.seguridad}</option>
                            <option>{f.options.bbdd}</option>
                        </optgroup>
                        <optgroup label={f.groups.other}>
                            <option>{f.options.otro}</option>
                        </optgroup>
                    </select>
                </div>
                <div class="form-group">
                    <label for="mensaje">{f.mensaje} <span class="field-required" aria-label={f.requerido}>*</span></label>
                    <textarea id="mensaje" placeholder={f.mensajePh} required
                              aria-describedby="error-mensaje" aria-required="true"></textarea>
                    <span class="field-error" id="error-mensaje" aria-live="polite"></span>
                </div>
                <button type="submit" class="btn-primary form-submit" aria-live="polite">{f.submit}</button>
            </form>
        </div>
    </div>
</section>

<script>
    const form    = document.getElementById('contactForm') as HTMLFormElement;
    const nombre  = document.getElementById('nombre')  as HTMLInputElement;
    const email   = document.getElementById('email')   as HTMLInputElement;
    const mensaje = document.getElementById('mensaje') as HTMLTextAreaElement;

    // Leer mensajes localizados desde data-attributes
    const msgs = {
        nombreReq:    form.dataset.valNombreReq!,
        emailReq:     form.dataset.valEmailReq!,
        emailInvalid: form.dataset.valEmailInvalid!,
        mensajeReq:   form.dataset.valMensajeReq!,
        mensajeShort: form.dataset.valMensajeShort!,
    };
    const txt = {
        submit:  form.dataset.submit!,
        sending: form.dataset.sending!,
        success: form.dataset.success!,
        error:   form.dataset.error!,
    };

    function showError(id: string, msg: string) {
        const el = document.getElementById(id);
        if (el) { el.textContent = msg; el.previousElementSibling?.classList.add('field-invalid'); }
    }
    function clearError(id: string) {
        const el = document.getElementById(id);
        if (el) { el.textContent = ''; el.previousElementSibling?.classList.remove('field-invalid'); }
    }
    function validateEmail(v: string) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

    nombre.addEventListener('blur', () => {
        if (!nombre.value.trim()) showError('error-nombre', msgs.nombreReq);
        else clearError('error-nombre');
    });
    email.addEventListener('blur', () => {
        if (!email.value.trim()) showError('error-email', msgs.emailReq);
        else if (!validateEmail(email.value.trim())) showError('error-email', msgs.emailInvalid);
        else clearError('error-email');
    });
    mensaje.addEventListener('blur', () => {
        if (!mensaje.value.trim()) showError('error-mensaje', msgs.mensajeReq);
        else if (mensaje.value.trim().length < 10) showError('error-mensaje', msgs.mensajeShort);
        else clearError('error-mensaje');
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn      = form.querySelector('button[type=submit]') as HTMLButtonElement;
        const honeypot = (document.getElementById('website') as HTMLInputElement).value;

        if (honeypot) { btn.textContent = txt.success; form.reset(); return; }

        let valid = true;
        if (!nombre.value.trim())                  { showError('error-nombre',  msgs.nombreReq);    valid = false; }
        if (!email.value.trim())                   { showError('error-email',   msgs.emailReq);     valid = false; }
        else if (!validateEmail(email.value))      { showError('error-email',   msgs.emailInvalid); valid = false; }
        if (!mensaje.value.trim())                 { showError('error-mensaje', msgs.mensajeReq);   valid = false; }
        else if (mensaje.value.trim().length < 10) { showError('error-mensaje', msgs.mensajeShort); valid = false; }
        if (!valid) return;

        const payload = {
            nombre:  nombre.value.trim(),
            email:   email.value.trim(),
            asunto:  (document.getElementById('asunto') as HTMLSelectElement).value,
            mensaje: mensaje.value.trim(),
        };

        btn.textContent = txt.sending;
        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');

        let resetTimer: ReturnType<typeof setTimeout>;
        try {
            const res = await fetch('/api/contact', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload),
            });
            if (!res.ok) throw new Error();
            btn.textContent = txt.success;
            btn.style.background = 'linear-gradient(135deg, #10b981, #059669)';
            form.reset();
        } catch {
            btn.textContent = txt.error;
            btn.style.background = 'linear-gradient(135deg, #ef4444, #dc2626)';
            btn.disabled = false;
        } finally {
            btn.setAttribute('aria-busy', 'false');
        }

        clearTimeout(resetTimer!);
        resetTimer = setTimeout(() => {
            btn.textContent = txt.submit;
            btn.style.background = '';
            btn.disabled = false;
        }, 3500);
    });
</script>
